// Prisma schema for household admin dashboard
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes      Note[]
  taskGroups TaskGroup[]
  events     Event[]
  bills      Bill[]
  billShares BillShare[]
  guestStays GuestStay[]
  allowlists Allowlist[]
  joinRequestsReviewed JoinRequest[]
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
}

model TaskGroup {
  id          String   @id @default(cuid())
  title       String
  color       String   @default("blue")
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tasks       Task[]

  @@index([authorId])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  completed   Boolean  @default(false)
  taskGroupId String
  taskGroup   TaskGroup @relation(fields: [taskGroupId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([taskGroupId])
  @@index([completed])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime?
  time        String?
  category    String   @default("other") // family, maintenance, appointment, other
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
  @@index([startDate])
  @@index([endDate])
}

model Bill {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  dueDate   DateTime
  paid      Boolean  @default(false)
  type      String   @default("recurring") // recurring, metered, one-time
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  billShares BillShare[]

  @@index([createdById])
  @@index([dueDate])
  @@index([type])
}

model BillShare {
  id        String   @id @default(cuid())
  billId    String
  bill      Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Float
  paid      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([billId])
  @@index([userId])
  @@index([paid])
}

model UtilityReading {
  id        String   @id @default(cuid())
  type      String   // electricity, water, gas, etc.
  value     Float
  maxValue  Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([date])
}

model GuestStay {
  id          String   @id @default(cuid())
  guestName   String
  fromDate    DateTime
  toDate      DateTime
  notes       String?  @db.Text
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
  @@index([fromDate])
}

model Allowlist {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("admin") // admin, superadmin
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model JoinRequest {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  status    String   @default("pending") // pending, approved, rejected
  reviewedById String?
  reviewedBy   User?    @relation(fields: [reviewedById], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
}
